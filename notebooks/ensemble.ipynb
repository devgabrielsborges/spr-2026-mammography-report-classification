        "def load_oof_probs(experiment_name):\n",
        "    # Placeholder for loading logic\n",
        "    # For example: return np.load(f\"oof_probs_{experiment_name}.npy\")\n",
        "    pass\n",
        "\n",
        "df = pd.read_csv(DATA_PATH)\n",
        "y = df[\"target\"].values"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Weighted Soft Voting"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def macro_f1_loss(weights, oof_probs_list, y_true):\n",
        "    weights = weights / np.sum(weights)\n",
        "    ensemble_probs = np.zeros_like(oof_probs_list[0])\n",
        "    for w, probs in zip(weights, oof_probs_list):\n",
        "        ensemble_probs += w * probs\n",
        "    preds = np.argmax(ensemble_probs, axis=1)\n",
        "    return -f1_score(y_true, preds, average='macro', zero_division=0)\n",
        "\n",
        "def optimize_weights(oof_probs_list, y_true):\n",
        "    n_models = len(oof_probs_list)\n",
        "    init_weights = [1.0 / n_models] * n_models\n",
        "    bounds = [(0, 1)] * n_models\n",
        "    \n",
        "    result = minimize(\n",
        "        macro_f1_loss, \n",
        "        init_weights, \n",
        "        args=(oof_probs_list, y_true), \n",
        "        method='SLSQP', \n",
        "        bounds=bounds\n",
        "    )\n",
        "    \n",
        "    return result.x / np.sum(result.x)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Logistic Regression Stacking"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def train_stacking_meta_learner(oof_probs_list, y_true):\n",
        "    X_meta = np.concatenate(oof_probs_list, axis=1)\n",
        "    skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=RANDOM_STATE)\n",
        "    \n",
        "    meta_model = LogisticRegression(class_weight='balanced', max_iter=1000)\n",
        "    meta_model.fit(X_meta, y_true)\n",
        "    \n",
        "    return meta_model"
      ]
    },
