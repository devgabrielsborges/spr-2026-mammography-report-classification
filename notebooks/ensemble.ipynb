      "source": [
        "# Ensemble Methods for BI-RADS Classification\n",
        "\n",
        "Combine the best-performing models from US2 and US3 via ensembling.  \n",
        "Implement weighted soft voting and logistic regression stacking.  \n",
        "Compare ensemble performance against the best single model."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "tags": [
          "parameters"
        ]
      },
      "outputs": [],
      "source": [
        "RANDOM_STATE = 42\n",
        "N_FOLDS = 5\n",
        "METRIC = \"f1_macro\"\n",
        "DATA_PATH = \"data/raw/train.csv\"\n",
        "ENSEMBLE_METHOD = \"soft_voting\"\n",
        "MLFLOW_EXPERIMENT = \"birads-ensemble\""
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import os\n",
        "import sys\n",
        "from pathlib import Path\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.metrics import (\n",
        "    ConfusionMatrixDisplay,\n",
        "    classification_report,\n",
        "    f1_score,\n",
        ")\n",
        "from sklearn.model_selection import StratifiedKFold\n",
        "from scipy.optimize import minimize\n",
        "\n",
        "COMPETITION = \"spr-2026-mammography-report-classification\"\n",
        "\n",
        "KAGGLE_INPUT = Path(\"/kaggle/input\") / COMPETITION\n",
        "if KAGGLE_INPUT.exists():\n",
        "    DATA_PATH = str(KAGGLE_INPUT / \"train.csv\")\n",
        "    IS_KAGGLE = True\n",
        "else:\n",
        "    IS_KAGGLE = False\n",
        "\n",
        "def _find_project_root() -> Path:\n",
        "    for p in [Path.cwd(), *Path.cwd().parents]:\n",
        "        if (p / \"pyproject.toml\").exists():\n",
        "            return p\n",
        "    return Path.cwd()\n",
        "\n",
        "ROOT = _find_project_root()\n",
        "_data_path = Path(DATA_PATH)\n",
        "if not _data_path.is_absolute():\n",
        "    _data_path = ROOT / _data_path\n",
        "DATA_PATH = str(_data_path)\n",
        "\n",
        "print(f\"Project root: {ROOT}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Load OOF Predictions"
